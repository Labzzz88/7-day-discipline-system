/* ============================================
   CSS Custom Properties (Design Tokens)
   All colors, radii, and shadows defined once
   ============================================ */
:root {
  /* Brand colors */
  --color-primary:        #007bff;
  --color-primary-dark:   #0056b3;
  --color-primary-light:  #e6f1fb;

  /* Semantic colors */
  --color-success:        #28a745;
  --color-success-bg:     #d4edda;
  --color-success-text:   #155724;
  --color-success-border: #28a745;

  --color-danger:         #dc3545;
  --color-danger-bg:      #f8d7da;
  --color-danger-text:    #721c24;
  --color-danger-border:  #dc3545;

  --color-warning:        #ffc107;
  --color-warning-bg:     #fff3cd;
  --color-warning-text:   #856404;
  --color-warning-border: #ffc107;

  --color-info:           #17a2b8;
  --color-info-bg:        #d1ecf1;
  --color-info-text:      #0c5460;
  --color-info-border:    #17a2b8;

  /* Neutrals */
  --color-text-primary:   #333333;
  --color-text-muted:     #666666;
  --color-bg-page:        #f4f7f6;
  --color-bg-surface:     #ffffff;
  --color-bg-subtle:      #f8f9fa;

  /* Shadows */
  --shadow-sm:  0 2px 10px rgba(0, 0, 0, 0.08);
  --shadow-md:  0 4px 15px rgba(0, 0, 0, 0.10);

  /* Spacing */
  --radius-sm:  5px;
  --radius-md:  10px;
  --radius-lg:  15px;
}

/* ============================================
   Base
   ============================================ */
body {
  font-family: Georgia, 'Times New Roman', serif; /* swap to your preferred stack */
  text-align: center;
  background-color: var(--color-bg-page);
  color: var(--color-text-primary);
  padding: 3rem;
}

/* ============================================
   Header
   ============================================ */
header {
  background: var(--color-bg-surface);
  padding: 2.5rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: flex-start;
  gap: 2.5rem;
  margin-bottom: 2.5rem;
}

.header-content {
  flex: 1;
  text-align: left;
}

/* ============================================
   Product image
   ============================================ */
.product-image {
  width: 100%;
  max-width: 18.75rem; /* 300px in rem */
  height: auto;
  object-fit: cover;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

/* ============================================
   CTA button
   Merged .cta-button and .cta-button-link —
   they shared identical rules, so use one block.
   ============================================ */
.cta-button,
.cta-button-link {
  background-color: var(--color-primary);
  color: #ffffff;
  padding: 0.9rem 1.875rem;
  border: none;
  border-radius: var(--radius-sm);
  font-size: 1.2rem;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;   /* changed from block — avoids forced full-width */
  width: fit-content;
  margin: 1.25rem auto;
  text-align: center;
  transition: background-color 0.3s;
}

.cta-button:hover,
.cta-button-link:hover {
  background-color: var(--color-primary-dark);
}

/* Accessibility: visible focus ring for keyboard users */
.cta-button:focus,
.cta-button-link:focus {
  outline: 2px solid var(--color-primary);
  outline-offset: 2px;
}

/* ============================================
   Typography helpers
   ============================================ */
.subheadline {
  font-size: 1.2em;
  color: var(--color-text-muted);
  margin: 0.9rem 0 1.5rem;
}

/* ============================================
   Callout blocks (hook / intro / product-intro)
   Shared structure, overridden per variant
   ============================================ */
.hook,
.intro,
.product-intro {
  padding: 1.25rem;
  border-radius: var(--radius-md);
  border-left: 4px solid transparent;
  margin: 1.25rem 0;
  border-top-left-radius: 0;    /* flat corner where left border meets top */
  border-bottom-left-radius: 0;
}

.hook {
  background-color: var(--color-warning-bg);
  border-left-color: var(--color-warning-border);
}

.hook h3 {
  color: var(--color-warning-text);
  margin-bottom: 0.9rem;
}

.hook ul {
  text-align: left;
  margin: 0.9rem 0;
}

.intro {
  background-color: var(--color-info-bg);
  border-left-color: var(--color-info-border);
}

.intro strong {
  color: var(--color-info-text);
}

.product-intro {
  background-color: var(--color-success-bg);
  border-left-color: var(--color-success-border);
}

.product-intro h2,
.product-intro h3 {
  color: var(--color-success-text);
  margin-bottom: 0.6rem;
}

.product-intro h3 {
  font-size: 1.4em;
  margin: 0.9rem 0;
}

/* ============================================
   Sections
   ============================================ */
section {
  background-color: var(--color-bg-surface);
  padding: 1.875rem;
  margin-bottom: 1.875rem;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  text-align: left;
}

section h2 {
  color: var(--color-primary);
  margin-bottom: 1.25rem;
  text-align: center;
}

/* ============================================
   Before / After grid
   ============================================ */
.transformation-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.875rem;
  margin-top: 1.25rem;
}

.before,
.after {
  padding: 1.25rem;
  border-radius: var(--radius-md);
  border-left: 4px solid transparent;
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

.before {
  background-color: var(--color-danger-bg);
  border-left-color: var(--color-danger-border);
}

.before h3 { color: var(--color-danger-text); }

.after {
  background-color: var(--color-success-bg);
  border-left-color: var(--color-success-border);
}

.after h3 { color: var(--color-success-text); }

/* ============================================
   How it works steps
   ============================================ */
#how-it-works ol {
  counter-reset: step-counter;
}

#how-it-works li {
  margin-bottom: 0.9rem;
  padding: 0.9rem;
  background-color: var(--color-bg-subtle);
  border-radius: 0.5rem;
  border-left: 4px solid var(--color-primary);
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

/* ============================================
   Bonus items
   ============================================ */
.bonus-item {
  background-color: var(--color-warning-bg);
  padding: 1.25rem;
  margin: 0.9rem 0;
  border-radius: var(--radius-md);
  border-left: 4px solid var(--color-warning-border);
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
}

.bonus-item h3 {
  color: var(--color-warning-text);
  margin-bottom: 0.6rem;
}

/* ============================================
   Who it's for
   ============================================ */
#who-its-for h3 {
  color: var(--color-danger);
  margin-top: 1.875rem;
  margin-bottom: 0.9rem;
}

/* ============================================
   Price block
   ============================================ */
.price {
  background-color: var(--color-primary);
  color: #ffffff;
  padding: 1.25rem;
  border-radius: var(--radius-md);
  text-align: center;
  margin: 1.25rem 0;
  font-size: 1.3em;
}

/* ============================================
   Responsive — mobile
   ============================================ */
@media (max-width: 48rem) { /* 768px → rem */
  body {
    padding: 1.5rem;
  }

  header {
    flex-direction: column;
    text-align: center;
    gap: 1.25rem;
  }

  .header-content {
    text-align: center;
  }

  .transformation-grid {
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  .product-image {
    max-width: 15.625rem; /* 250px */
  }

  section {
    padding: 1.25rem;
  }
}
